# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://social:social@localhost:5432/social
POSTGRES_USER=social
POSTGRES_PASSWORD=social
POSTGRES_DB=social

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ─── S3 / MinIO ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=media
S3_PUBLIC_URL=http://localhost:9000/media
S3_FORCE_PATH_STYLE=true

# ─── Rate limits ──────────────────────────────────────────
RATE_LIMIT_POSTS_PER_HOUR=100
RATE_LIMIT_LIKES_PER_HOUR=1000

# ─── Frontend (Next.js) ───────────────────────────────────
NEXT_PUBLIC_GRAPHQL_HTTP=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS=ws://localhost:4000/graphql
