{
  "name": "social-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade social media platform (GraphQL + Next.js)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "lint": "npm run lint --workspace=server && npm run lint --workspace=web",
    "test": "npm run test --workspace=server",
    "migrate": "flyway -configFiles=db/flyway.conf migrate",
    "seed": "npm run seed --workspace=server",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
